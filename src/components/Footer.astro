---
import { AppConfig } from '../data/app.config';
import { getRouteUrl } from '../data/routes.config';
import BrandWordMark from './BrandWordMark.astro';
import { Clock, MapPin, Mail } from '@lucide/astro';
---

<footer>
  <div class="container-fluid">
    <div class="content">
      <div class="branding">
        <p class="name"><BrandWordMark /></p>
        <p class="tagline">{ AppConfig.brand_tagline }</p>

        <div class="info">
          <p>
            <MapPin />
            <span>{ AppConfig.address }</span>
          </p>
          <p>
            <Mail />
            <span>{ AppConfig.email }</span>
          </p>
          <p>
            <Clock />
            <span>{ AppConfig.time }</span>
          </p>
        </div>
      </div>

      <div class="quick-links">
        <h3>Quick Links</h3>
        <div class="links">
          <a href={getRouteUrl("home-page")}>Home</a>
          <a href={getRouteUrl("about-page")}>About</a>
          <a href={getRouteUrl("services-page")}>Services</a>
          <a href={getRouteUrl("about-page")}>Portfolio</a>
          <a href={getRouteUrl("contact-page")}>Contact</a>
        </div>
      </div>

      <div class="services">
        <h3>Services</h3>
        <div class="links">
          <a href="/services/custom-software">Custom software</a>
          <a href="/services/web-development">Web Development</a>
          <a href="/services/mobile-apps">Mobile Apps</a>
          <a href="/services/seo">SEO Services</a>
        </div>
      </div>

      <div class="contacts">
        <h3>Connect With Us</h3>
        <div class="socials">
          <a href={ AppConfig.twitter }  aria-label="Twitter">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"
              ></path>
            </svg>
          </a>
          <a href={ AppConfig.linkedin } aria-label="LinkedIn">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
              ></path>
            </svg>
          </a>
          <a href={ AppConfig.instagram } aria-label="Instagram">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zM12 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zM12 16c-2.209 0-4-1.791-4-4s1.791-4 4-4 4 1.791 4 4-1.791 4-4 4zm7.846-10.405c0 .795-.646 1.441-1.441 1.441-.795 0-1.441-.646-1.441-1.441 0-.795.646-1.441 1.441-1.441.795 0 1.441.646 1.441 1.441z"
              ></path>
            </svg>
          </a>
        </div>
        <p>Follow us for updates and insights</p>
      </div>
    </div>

    <div class="copyrights">
      <p class="text">&copy; {AppConfig.currentYear} <BrandWordMark />. All rights reserved.</p>
      <div class="documents">
        <a href={getRouteUrl("privacy-policy")}>Privacy Policy</a>
        <a href={getRouteUrl("terms-and-conditions")}>Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
