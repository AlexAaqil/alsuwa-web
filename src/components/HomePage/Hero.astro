---
import { AppConfig } from '../../data/app.config';
import { getRouteUrl } from '../../data/routes.config';
import { Video } from "@lucide/astro";
---

<section class="Hero">
    <div class="container-fluid">
        <div class="hero-text">
            <div class="content">
                <h1 class="punchline"><span class="text-accent">Growth infrastructure</span> for ambitious enterprises.</h1>
                <!-- <p class="description">We align market strategy, deploy high-converting web engines, and engineer custom operational software - transforming local operations into dominant market leaders.</p> -->
                <p class="description">We help business owners create striking brand identities and  systems like e-commerce, POS, ERPs and HRMS so that your business has the growth infrastructure it needs to scale.</p>
            </div>

            <div class="hero-btns">
                <a href={AppConfig.whatsappScheduleCall} rel="noopener noreferrer" aria-label="Chat with us on WhatsApp" class="btn btn-primary">
                    <Video />
                    <span>Schedule a call</span>
                </a>

                <a href={ getRouteUrl("contact-page") } class="btn btn-outline">Get in touch</a>
            </div>
        </div>
    </div>
</section>
