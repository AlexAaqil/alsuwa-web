---
import { getRouteUrl } from '../../data/routes.config';
---

<section class="Hero">
    <div class="container-fluid">
        <div class="hero_text">
            <div class="content">
                <h1 class="punchline">Growth infrastructure for ambitious enterprises.</h1>
                <p class="description">We align market strategy, deploy high-converting web engines, and engineer custom operational software - transforming local operations into dominant market leaders.</p>
            </div>

            <div class="hero_btns">
                <a href={ getRouteUrl("contact-page") } class="link-btn primary">Schedule a call</a>

                <a href={ getRouteUrl("contact-page") } class="link-btn outline">Get in touch</a>
            </div>
        </div>
    </div>
</section>
