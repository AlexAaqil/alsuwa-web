---
import { getRouteUrl } from '../../data/routes.config';
---

<section class="Hero">
    <div class="container-fluid">
        <div class="hero-text">
            <div class="content">
                <h1 class="punchline"><span class="text-accent">Growth infrastructure</span> for ambitious enterprises.</h1>
                <!-- <p class="description">We align market strategy, deploy high-converting web engines, and engineer custom operational software - transforming local operations into dominant market leaders.</p> -->
                <p class="description">As a business owner, you don't just wake up wanting a website, a logo, a CRM or an app. We help you grow smartly through custom software, visual design and digital systems.</p>
            </div>

            <div class="hero-btns">
                <a href={ getRouteUrl("contact-page") } class="btn btn-primary">Schedule a call</a>

                <a href={ getRouteUrl("contact-page") } class="btn btn-outline">Get in touch</a>
            </div>
        </div>
    </div>
</section>
