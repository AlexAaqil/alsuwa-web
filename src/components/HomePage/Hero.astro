---
import { AppConfig } from '../../data/app.config';
import { getRouteUrl } from '../../data/routes.config';
import { Video } from "@lucide/astro";
---

<section class="Hero">
    <div class="container-fluid">
        <div class="hero-text">
            <div class="content">
                <h1 class="punchline"><span class="text-accent">Custom Software</span>, Websites & Business Systems for Growing Businesses.</h1>
                <p class="description">We help businesses scale through custom software, e-commerce platforms, ERP Systems, management systems and visual design.</p>
            </div>

            <div class="hero-btns">
                <a href={AppConfig.whatsappScheduleCall} rel="noopener noreferrer" aria-label="Chat with us on WhatsApp" class="btn btn-primary">
                    <Video />
                    <span>Schedule a call</span>
                </a>

                <a href={ getRouteUrl("contact-page") } class="btn btn-outline">Get in touch</a>
            </div>
        </div>
    </div>
</section>
