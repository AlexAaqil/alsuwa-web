---
import Layout from '../layouts/Layout.astro';
import HomePage from '../components/HomePage/index.astro';
import { AppConfig } from '../data/app.config';

// JSON-LD object
const schemaData = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "Organization",
	"name": AppConfig.brand_name,
	"url": "https://alsuwa.com",
	"sameAs": [
		AppConfig.linkedin,
		AppConfig.instagram
	],
	"address": {
		"@type": "PostalAddress",
		"addressLocality": "Kiambu",
		"addressCountry": "KE"
	}
});
---

<Layout>
	<Fragment slot="head">
		<meta name="description" content="Alsuwa is a business growth company specializing in helping ambitious businesses gain more: customers, sales, efficiency and profits by combining strategy, visual design and custom software development into solutions that help you grow smartly." />

		<!-- Open Graph tags for social sharing -->
		<meta property="og:title" content={`${AppConfig.brand_name} | ${AppConfig.brand_tagline}`} />
		<meta property="og:description" content="Alsuwa is a business growth company specializing in helping ambitious businesses gain more: customers, sales, efficiency and profits by combining strategy, visual design and custom software development into solutions that help you grow smartly." />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={AppConfig.images.logos.alsuwaLogo.src} />
		
		<!-- Twitter Card tags -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={AppConfig.brand_name} />
		<meta name="twitter:description" content="Alsuwa is a business growth company specializing in helping ambitious businesses gain more: customers, sales, efficiency and profits by combining strategy, visual design and custom software development into solutions that help you grow smartly." />
		<meta name="twitter:image" content={AppConfig.images.logos.alsuwaLogo.src} />
		
		<!-- Canonical URL -->
		<link rel="canonical" href="https://alsuwa.com" />
		
		<!-- Robots meta tag -->
		<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />

		<!-- set:html to inject the stringified JSON safely -->
		<script type="application/ld+json" set:html={schemaData}></script>
	</Fragment>

	<HomePage />
</Layout>
